{
  "manifest_version": 3,
  "name": "Evitrace",
  "version": "1.0.0",
  "description": "Capture evidence and log competencies directly from your active tab.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Evitrace",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://evitrace.vercel.app/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab", 
    "storage", 
    "alarms", 
    "notifications", 
    "tabs", 
    "scripting", 
    "offscreen"
  ],
  "host_permissions": [
    "https://evitrace.vercel.app/*",
    "https://sljzzqxjwtqdzltrjrhc.supabase.co/*"
  ]
}