{
  "manifest_version": 3,
  "name": "Evitrace Capture",
  "version": "1.0.0",
  "description": "Capture evidence and log competencies directly from your active tab.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Log Evidence",
    "default_icon": {
      "16": "icons/evitrace-icon.svg",
      "32": "icons/evitrace-icon.svg",
      "48": "icons/evitrace-icon.svg",
      "128": "icons/evitrace-icon.svg"
    }
  },
  "icons": {
    "16": "icons/evitrace-icon.svg",
    "32": "icons/evitrace-icon.svg",
    "48": "icons/evitrace-icon.svg",
    "128": "icons/evitrace-icon.svg"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "storage", "alarms", "notifications"],
  "host_permissions": ["http://localhost/*", "https://*.supabase.co/*"]
}
